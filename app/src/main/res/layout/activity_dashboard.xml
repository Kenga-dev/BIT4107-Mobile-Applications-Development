<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="32dp"
    android:gravity="center">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Teacher Dashboard"
        android:textSize="28sp"
        android:textStyle="bold"
        android:layout_marginBottom="48dp" />

    <Button
        android:id="@+id/btnRegisterStudent"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Register New Student"
        android:layout_marginBottom="16dp" />

    <Button
        android:id="@+id/btnViewStudents"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="View Registered Students"
        android:layout_marginBottom="16dp" />

    <Button
        android:id="@+id/btnConductAssessment"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Conduct Assessment" />

</LinearLayout>